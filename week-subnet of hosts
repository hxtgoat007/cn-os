#include <stdio.h>

int a[10][10], n, i, j, root;

void adj(int k)
{
    printf("Adjacent nodes of root node %d are:\n", k);

    for (j = 1; j <= n; j++)
    {
        if (a[k][j] == 1 || a[j][k] == 1 && k != j)
        {
            printf("%d\t", j);
        }
    }
    printf("\n");
}

int main()
{
    printf("Enter number of nodes: ");
    scanf("%d", &n);

    printf("Enter the adjacency matrix:\n");
    for (i = 1; i <= n; i++)
    {
        for (j = 1; j <= n; j++)
        {
            scanf("%d", &a[i][j]);
        }
    }

    printf("Enter root node: ");
    scanf("%d", &root);

    adj(root);

    return 0;
}
