#include <stdio.h>
#include <unistd.h>
#include <string.h>
#include <stdlib.h>

int main()
{
    int fd[2];
    pid_t pid;
    char buffer[100];
    char message[] = "Hello from parent";

    if (pipe(fd) == -1)
    {
        perror("pipe failed");
        exit(1);
    }

    pid = fork();

    if (pid == 0)
    {
        // child process
        close(fd[1]);
        read(fd[0], buffer, sizeof(buffer));
        printf("Child received message: %s\n", buffer);
        close(fd[0]);
    }
    else
    {
        // parent process
        close(fd[0]);
        write(fd[1], message, strlen(message) + 1);
        close(fd[1]);
    }

    return 0;
}
